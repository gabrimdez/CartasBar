---
import { Image } from 'astro:assets';
import type { Plato } from '../lib/menu';
import { formatPrecio } from '../lib/menu';
import { getFotoPlato } from '../lib/fotos';
import AllergenBadge from './AllergenBadge.astro';

interface Props {
  plato: Plato;
  barSlug: string;
}

const { plato, barSlug } = Astro.props;

// Foto opcional por convención de nombre (ver src/lib/fotos.ts).
const foto = getFotoPlato(barSlug, plato.nombre);
---

<article class="dish">
  <div class="dish-head">
    <h3 class="dish-name">{plato.nombre}</h3>
    <span class="dish-price">{formatPrecio(plato.precio)}</span>
  </div>

  {plato.descripcion && <p class="dish-desc">{plato.descripcion}</p>}

  {
    plato.alergenos.length > 0 && (
      <ul class="dish-allergens" aria-label="Alérgenos">
        {plato.alergenos.map((id) => (
          <li>
            <AllergenBadge id={id} />
          </li>
        ))}
      </ul>
    )
  }

  {
    foto && (
      <Image
        class="dish-photo"
        src={foto}
        alt={`Foto de ${plato.nombre}`}
        widths={[240, 480, 720]}
        sizes="(max-width: 700px) 92vw, 640px"
        loading="lazy"
        decoding="async"
      />
    )
  }
</article>

<style>
  .dish {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--c-borde);
  }

  .dish:last-child {
    border-bottom: 0;
  }

  .dish-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .dish-name {
    font-size: 1rem;
    font-weight: 600;
  }

  .dish-price {
    flex: none;
    font-weight: 700;
    color: var(--c-primario);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .dish-desc {
    margin-top: 0.2rem;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .dish-allergens {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.55rem 0 0;
    padding: 0;
    list-style: none;
  }

  .dish-photo {
    display: block;
    width: 100%;
    /* Banda compacta: alto acotado y recorte para que no domine la pantalla. */
    height: clamp(150px, 42vw, 200px);
    object-fit: cover;
    margin-top: 0.65rem;
    border-radius: 0.6rem;
  }
</style>
