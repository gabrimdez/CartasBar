---
import type { AllergenId } from '../lib/allergens';
import { ALERGENOS_POR_ID } from '../lib/allergens';
import AllergenIcon from './AllergenIcon.astro';

interface Props {
  id: AllergenId;
}

const { id } = Astro.props;
const alergeno = ALERGENOS_POR_ID[id];
---

<span class="badge">
  <span class="badge-icon"><AllergenIcon id={id} /></span>
  <span class="badge-label">{alergeno.etiqueta}</span>
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    padding: 0.22em 0.6em 0.22em 0.45em;
    border: 1px solid var(--c-borde);
    border-radius: 999px;
    background: var(--c-tenue);
    font-size: 0.78rem;
    line-height: 1.2;
    white-space: nowrap;
  }

  /* El icono hereda el color primario del tema vía currentColor. */
  .badge-icon {
    display: inline-flex;
    color: var(--c-primario);
  }
</style>
