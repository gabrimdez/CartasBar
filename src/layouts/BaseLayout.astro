---
import '../styles/global.css';

interface Props {
  title: string;
  /** Colores del bar; se inyectan como CSS custom properties en <html>. */
  tema: { primario: string; fondo: string; texto: string };
  description?: string;
}

const { title, tema, description } = Astro.props;

// El tema del bar se aplica sin tocar componentes: estos solo usan var(--c-*).
const temaVars = [
  `--c-primario:${tema.primario}`,
  `--c-fondo:${tema.fondo}`,
  `--c-texto:${tema.texto}`,
].join(';');
---

<!doctype html>
<html lang="es" style={temaVars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content={tema.primario} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
